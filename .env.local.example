# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — keys stay on your machine.
#
# After saving, restart `npm run dev` (Vite picks up env at boot).

# Your Google Sheet URL (full URL with /spreadsheets/d/{ID}/...)
VITE_SHEET_URL=

# Your Google Sheets API key from Cloud Console → Credentials.
# Should be restricted to HTTP referrers (http://localhost:5173/*) and to the
# Sheets API. The key shipping in the bundle is normal — the restriction is what
# keeps it safe.
VITE_GOOGLE_API_KEY=
